local function NotifyAllRoles()
    local allRoles = GetAllRoles()
    local localPlayer = game:GetService("Players").LocalPlayer
    local selfRole = "Innocent"
    
    for name, data in pairs(allRoles) do
        if name == localPlayer.Name then
            selfRole = data.Role
            break
        end
    end
    
    local selfColor = Color3.fromRGB(0, 255, 0)
    if selfRole == "Murderer" then
        selfColor = Color3.fromRGB(255, 0, 0)
    elseif selfRole == "Sheriff" then
        selfColor = Color3.fromRGB(0, 0, 255)
    end
    
    ShowRoleNotification("YOU ARE: " .. selfRole:upper(), selfColor, 0.3, 4)
    
    task.wait(0.5)
    
    local murderer = Roles.Murderer
    local sheriff = Roles.Sheriff
    
    if murderer then
