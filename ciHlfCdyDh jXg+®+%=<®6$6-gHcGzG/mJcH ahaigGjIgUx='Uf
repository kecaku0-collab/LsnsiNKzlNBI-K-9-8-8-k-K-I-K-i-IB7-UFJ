local function LoadSyfta()
    local url = "https://raw.githubusercontent.com/UniversalScripter1/ProjectSyfta/refs/heads/main/Notification"
    local success, result = pcall(function()
        return game:HttpGet(url)
    end)
    if success and result and result ~= "" then
        local func, err = loadstring(result)
        if func then
            return func()
        else
            warn("Syfta Loader: Syntax Error in External Script - " .. tostring(err))
        end
    else
        warn("Syfta Loader: Connection Error. Could not fetch from GitHub.")
    end
    return nil
end

local notif = LoadSyfta()

local function ExtractAssetId(icon)
    if not icon then return nil end
    if type(icon) == "number" then return icon end
    local s = tostring(icon)
    local id = s:match("(%d+)")
    return tonumber(id)
end

local function SendSyftaNotification(title, text, duration, icon)
    duration = duration or 5
    if notif and type(notif.Notification) == "function" then
        local iconId = ExtractAssetId(icon) or 54952350
        local ok, _ = pcall(function()
            notif:Notification(
                title or "Project Syfta",
                text or "",
                "GothamBold",
                "Gotham",
                duration,
                iconId,
                nil,
                "light"
            )
        end)
        if not ok then
            StarterGui:SetCore("SendNotification", {
                ["Title"] = title or "Project Syfta",
                ["Text"] = text or "",
                ["Duration"] = duration,
                ["Icon"] = icon or "rbxassetid://89804924525665"
            })
        end
    else
        StarterGui:SetCore("SendNotification", {
            ["Title"] = title or "Kero Hub",
            ["Text"] = text or "",
            ["Duration"] = duration,
            ["Icon"] = icon or "rbxassetid://89804924525665"
        })
    end
end

