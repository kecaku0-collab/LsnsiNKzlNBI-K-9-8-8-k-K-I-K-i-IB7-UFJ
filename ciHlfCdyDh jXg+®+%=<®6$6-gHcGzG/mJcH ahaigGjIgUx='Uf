local Roles = { Murderer = nil, Sheriff = nil, Hero = nil, Innocent = {}, AllPlayers = {} }

local function GetAllRoles()
    local players = game:GetService("Players")
    local localPlayer = players.LocalPlayer
    local allRoles = {}
    
    for _, player in ipairs(players:GetPlayers()) do
        local role = "Innocent"
        local hasKnife = false
        local hasGun = false
        
        local backpack = player:FindFirstChild("Backpack")
        if backpack then
            if backpack:FindFirstChild("Knife") then hasKnife = true end
            if backpack:FindFirstChild("Gun") then hasGun = true end
        end
        
        local character = player.Character
        if character then
            if character:FindFirstChild("Knife") then hasKnife = true end
            if character:FindFirstChild("Gun") then hasGun = true end
        end
        
        if hasKnife then
            role = "Murderer"
        elseif hasGun then
            role = "Sheriff"
        else
            role = "Innocent"
        end
        
        allRoles[player.Name] = {
            Role = role,
            IsAlive = character and character:FindFirstChild("Humanoid") and character.Humanoid.Health > 0 or false,
            HasKnife = hasKnife,
            HasGun = hasGun
        }
        
        if role == "Murderer" then
            Roles.Murderer = player.Name
        elseif role == "Sheriff" then
            Roles.Sheriff = player.Name
        end
    end
    
    Roles.AllPlayers = allRoles
    return allRoles
end

