-- Targeting loop (DetectMode-aware)
task.spawn(function()
    while task.wait(0.03) do -- V40: faster polling
        local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if myRoot and SilentSettings.Enabled then
            local potential = {}
            local mousePos = Vector2.new(LocalPlayer:GetMouse().X, LocalPlayer:GetMouse().Y)
            local Camera = workspace.CurrentCamera

            for _, v in pairs(Players:GetPlayers()) do
                if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild(SilentSettings.TargetPart) then
                    local part = v.Character[SilentSettings.TargetPart]
                    local dist3D = (myRoot.Position - part.Position).Magnitude
                    if dist3D < SilentSettings.MaxDistance then
                        -- Screen distance for mouse mode
                        local screenPos = Camera:WorldToViewportPoint(part.Position)
                        local onScreen = screenPos.Z > 0
                        local screenDist = onScreen
                            and (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                            or math.huge
                        table.insert(potential, {
                            Part = part,
                            Role = GetSilentRole(v),
                            Dist = dist3D,
                            ScreenDist = screenDist
                        })
                    end
                end
            end

            -- Role-aware priority: if YOU have knife -> prefer Sheriff, if YOU have gun -> prefer Murderer
            local myBP = LocalPlayer.Backpack
            local myChar2 = LocalPlayer.Character
            local iHaveKnife = myBP and (myBP:FindFirstChild("Knife") or (myChar2 and myChar2:FindFirstChild("Knife")))
            local iHaveGun   = myBP and (myBP:FindFirstChild("Gun")   or (myChar2 and myChar2:FindFirstChild("Gun")))

            local priorityRole = nil
            if iHaveKnife then
                priorityRole = "Sheriff"
            elseif iHaveGun then
                priorityRole = "Murderer"
            end

            -- First pass: try to find a priority target
            local target = nil
            if priorityRole then
                if SilentSettings.DetectMode == "Nearest Mouse" then
                    local best = math.huge
                    for _, d in pairs(potential) do
                        if d.Role == priorityRole and d.ScreenDist < best then
                            target = d.Part; best = d.ScreenDist
                        end
                    end
                else
                    local best = SilentSettings.MaxDistance
                    for _, d in pairs(potential) do
                        if d.Role == priorityRole and d.Dist < best then
                            target = d.Part; best = d.Dist
                        end
                    end
                end
            end

            -- Fallback: no priority target found, pick anyone by DetectMode
            if not target then
                if SilentSettings.DetectMode == "Nearest Mouse" then
                    local best = math.huge
                    for _, d in pairs(potential) do
                        if d.ScreenDist < best then target = d.Part; best = d.ScreenDist end
                    end
                else
                    local best = SilentSettings.MaxDistance
                    for _, d in pairs(potential) do
                        if d.Dist < best then target = d.Part; best = d.Dist end
                    end
                end
            end

            CurrentTargetPart = target
            if target and target.Parent then
                CurrentTargetPos = target.Position
                CurrentTargetVelocity = target.AssemblyLinearVelocity or target.Velocity or Vector3.new(0,0,0)
            else
                CurrentTargetPart = nil
                CurrentTargetPos = nil
                CurrentTargetVelocity = nil
            end
        else
            CurrentTargetPart = nil; CurrentTargetPos = nil; CurrentTargetVelocity = nil
        end
    end
end)

-- Hook (AimMode-aware: Silent Aim = V22, Instant Throw = V39)
local mt = getrawmetatable(game)
local oldNamecall = mt.__namecall
setreadonly(mt, false)

mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    local name = tostring(self)

    if method == "FireServer"
        and (name == "KnifeThrown" or name == "Shoot")
        and SilentSettings.Enabled
        and CurrentTargetPos and CurrentTargetVelocity
    then
        local isKnife = (name == "KnifeThrown")
        local safeVel = CurrentTargetVelocity or Vector3.new(0, 0, 0)

        if SilentSettings.AimMode == "Silent Aim" then
            -- V40: full velocity + gravity + dynamic height offset prediction, lookAt redirect
            local t = isKnife
                and (SilentSettings.KnifePrediction * SilentSettings.ThrowMulti)
                or SilentSettings.GunPrediction
            local heightOffset = GetPredictedHeightOffset(safeVel)
            local basePos = CurrentTargetPos + heightOffset
            local predictedPos = basePos + (safeVel * t)
            if math.abs(safeVel.Y) > 1 then
                predictedPos = predictedPos + Vector3.new(0, 0.5 * SilentSettings.GravityAdjustment * (t ^ 2), 0)
            end
            if typeof(args[1]) == "CFrame" then
                args[1] = CFrame.lookAt(args[1].Position, predictedPos)
                args[2] = CFrame.new(predictedPos)
                return oldNamecall(self, unpack(args))
            end

        else
            -- Instant Throw (V22): simple snappy redirect, preserves original throw arc rotation
            local t = isKnife and SilentSettings.KnifePrediction or SilentSettings.GunPrediction
            local predictedPos = CurrentTargetPos + (safeVel * t)
            if typeof(args[1]) == "CFrame" then
                args[1] = CFrame.new(predictedPos) * args[1].Rotation
                return oldNamecall(self, unpack(args))
            end
        end
    end

    return oldNamecall(self, ...)
end)

setreadonly(mt, true)

